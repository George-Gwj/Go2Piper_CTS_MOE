+    def _create_stair_scene(self, env_id: int, direction: int) -> list[str]:
+        base_path = self._env_task_scene_path(env_id)
+        self._define_xform(base_path)
+        prim_paths = []
+        num_steps = 5
+        step_depth = 0.34
+        step_width = 1.20
+        step_height = 0.10
+        color = (0.10, 0.65, 0.20) if direction > 0 else (0.45, 0.18, 0.75)
+        for step_idx in range(num_steps):
+            height_index = step_idx + 1 if direction > 0 else num_steps - step_idx
+            height = step_height * height_index
+            x_pos = 0.75 + step_depth * step_idx
+            prim_paths.append(
+                self._create_static_box(
+                    f"{base_path}/stair_{step_idx}",
+                    pos=(x_pos, 0.0, height / 2.0),
+                    size=(step_depth, step_width, height),
+                    color=color,
+                )
+            )
+        return prim_paths
+
+    def _define_xform(self, prim_path: str):
+        stage = self.sim.stage
+        if not stage.GetPrimAtPath(prim_path).IsValid():
+            UsdGeom.Xform.Define(stage, prim_path)
+
+    def _create_static_box(
+        self,
+        prim_path: str,
+        pos: tuple[float, float, float],
+        size: tuple[float, float, float],
+        color: tuple[float, float, float],
+    ) -> str:
+        stage = self.sim.stage
+        cube = UsdGeom.Cube.Define(stage, prim_path)
+        cube.CreateSizeAttr(1.0)
+
+        xform = UsdGeom.Xformable(cube.GetPrim())
+        xform.ClearXformOpOrder()
+        xform.AddTranslateOp().Set(Gf.Vec3d(*pos))
+        xform.AddScaleOp().Set(Gf.Vec3f(*size))
+
+        cube.CreateDisplayColorAttr([Gf.Vec3f(*color)])
+        UsdPhysics.CollisionAPI.Apply(cube.GetPrim())
+        return prim_path
 
